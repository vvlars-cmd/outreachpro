# ═══════════════════════════════════════════════════════════
# OutreachPro + CycleWASH — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── ANTHROPIC (required for AI personalisation + copilot) ──
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── APIFY (required for Google Maps lead scraping) ──
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GOOGLE / GMAIL (required for draft creation + sending) ──
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxx
# Redirect URI — must match Google Cloud Console exactly
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ── SERVER ──
PORT=3000
NODE_ENV=production
